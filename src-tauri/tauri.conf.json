{
  "productName": "Initium",
  "version": "1.0.2",
  "identifier": "com.initium.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Initium - Dashboard Intelligent",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "maximizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["French", "English"],
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Initium",
    "category": "Utility",
    "shortDescription": "Dashboard Intelligent Multi-Plateforme",
    "longDescription": "Initium est un tableau de bord intelligent pour lancer vos applications et sites web préférés."
  }
}